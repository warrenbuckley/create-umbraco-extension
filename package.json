{
  "name": "create-umbraco-extension",
  "version": "0.1.0-alpha.1",
  "description": "Scaffold Umbraco backoffice extensions interactively",
  "type": "module",
  "bin": {
    "create-umbraco-extension": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "umbraco",
    "scaffold",
    "cli",
    "backoffice",
    "extensions",
    "create"
  ],
  "license": "MIT",
  "publishConfig": {
    "tag": "alpha"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/warrenbuckley/create-umbraco-extension"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "build:watch": "tsc --watch",
    "dev": "npm run build && node scripts/dev.mjs",
    "dev:fresh": "npm run build && node scripts/dev.mjs --fresh",
    "lint": "oxlint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli": "npm run build && node dist/index.js --type dashboard --prefix Dev.Test --name \"Test Dashboard\" --umbraco-version 17 --section Umb.Section.Content --example --dry-run --json",
    "test:cli:write": "npm run build && node dist/index.js --type dashboard --prefix Dev.Test --name \"Test Dashboard\" --umbraco-version 17 --section Umb.Section.Content --example --cwd /tmp/create-umb-test",
    "test:e2e": "npm run build && node scripts/test-e2e.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
