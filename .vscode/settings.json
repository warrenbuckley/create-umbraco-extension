{
  // TypeScript — use the workspace's own TypeScript version
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,

  // Oxlint — use as the linter, disable any ESLint integration
  "oxc.enable": true,
  "eslint.enable": false,
  "oxc.ignore": ["src/templates/**"],

  // lit-plugin — disable for template files which contain {{TOKEN}} placeholders
  // that are not valid custom element tag names or TypeScript syntax
  "lit-plugin.rules.no-invalid-tag-name": "off",

  // Editor — no formatter yet (oxfmt deferred until 1.0)
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },

  // Vitest — auto-discover tests
  "vitest.enable": true,

  // Hide compiled output and deps from explorer and search
  "files.exclude": {
    "node_modules": true,
    "dist": true
  },
  "search.exclude": {
    "node_modules": true,
    "dist": true,
    "*.js.map": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true
  }
}
